# This directory contains personal Apple Health data.
# Default-deny: ignore EVERYTHING, then explicitly allow only non-personal code.

/*
!/.gitignore
!/README.md
!/LICENSE
!/dashboard/
!/docs/

# docs/ holds the README screenshot only; the generated synthetic JSON is rebuildable.
/docs/sample_summary.json
/docs/sample_detail.json

# Within the dashboard, keep code/tooling but exclude anything with real readings.
/dashboard/data/
/dashboard/screenshots/
/dashboard/sleep-dashboard.html
/dashboard/.playwright-mcp/

# OS / editor noise
.DS_Store
